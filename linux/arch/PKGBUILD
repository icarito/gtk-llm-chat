pkgname=gtk-llm-chat
pkgver=4.0.4
pkgrel=1
pkgdesc=""
arch=('any')
url="https://github.com/icarito/gtk-llm-chat/"
license=('GPL-2.0-or-later')
groups=()
depends=(
	'libadwaita'
	'python-llm'
	'python-llm-openrouter'
	'python-gobject'
)
makedepends=(
	'python-build'
	'python-installer'
	'python-wheel'
)
checkdepends=()
optdepends=()
provides=()
conflicts=()
replaces=()
source=("$url/releases/download/v$pkgver/gtk_llm_chat-$pkgver.tar.gz")
sha256sums=('910a19bdff7098d16ff8e33ebaa93e852a8a7307137fbf68c76eea9501eda244')

#prepare() {
#	cd "$srcdir/$pkgname-v$pkgver/source"
#
#	sed -i "/pip install/d" Makefile
#}

build() {
	cd "$srcdir/gtk_llm_chat-$pkgver"

	python -m build --wheel --no-isolation
}

package() {
	cd "$srcdir/gtk_llm_chat-$pkgver"

	python -m installer --destdir="$pkgdir" dist/*.whl
}
